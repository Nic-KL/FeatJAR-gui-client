{
  "name": "workflow-standalone",
  "version": "2.6.0-next",
  "private": true,
  "description": "Standalone browser-app for the Workflow example",
  "homepage": "https://www.eclipse.org/glsp/",
  "bugs": "https://github.com/eclipse-glsp/glsp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-glsp/glsp-client.git"
  },
  "author": {
    "name": "Eclipse GLSP"
  },
  "contributors": [
    {
      "name": "Eclipse GLSP Project",
      "email": "glsp-dev@eclipse.org",
      "url": "https://projects.eclipse.org/projects/ecd.glsp"
    }
  ],
  "main": "lib",
  "types": "lib",
  "scripts": {
    "all": "yarn clean && yarn install && yarn lint && yarn test",
    "build": "yarn compile && yarn bundle",
    "bundle": "webpack",
    "clean": "rimraf lib *.tsbuildinfo app/bundle.js app/bundle.js.map app/css",
    "compile": "tsc -b",
    "lint": "eslint --ext .ts,.tsx ./src",
    "start:exampleServer": "yarn ts-node ./scripts/start-example-server.ts",
    "watch": "tsc -w && yarn watch:bundle",
    "watch:bundle": "webpack -w"
  },
  "dependencies": {
    "@eclipse-glsp/client": "2.6.0",
    "inversify-logger-middleware": "^3.1.0",
    "@vscode/codicons": "^0.0.36"
  },
  "devDependencies": {
    "@types/tar": "6.1.5",
    "circular-dependency-plugin": "^5.2.2",
    "css-loader": "^6.7.1",
    "inversify": "^6.1.3",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "source-map-loader": "^4.0.0",
    "style-loader": "^3.3.1",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "balloon-css": "^0.5.0",
        "@eclipse-glsp/dev": "next",
    "@types/lodash": "4.14.191",
    "@types/node": "20.x",
    "concurrently": "^8.2.2",
    "lerna": "^9.0.0",
    "mocha-ctrf-json-reporter": "^0.0.9",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20",
    "yarn": ">=1.7.0 <2"
  },
  "publishConfig": {
    "access": "public"
  }
}
