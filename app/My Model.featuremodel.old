<?xml version="1.0" encoding="UTF-8"?>
<featJAR:FeatureModel xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:featJAR="https://github.com/FeatureIDE/FeatJAR" id="1" name="VehicleProductLine">
  <attributes key="domain" value="automotive"/>
  <attributes key="version" value="1.0"/>
  <roots id="2" name="Vehicle" featureType="CONCRETE">
    <attributes key="level" value="root"/>
    <groupNodeList id="10" name="MainGroup">
      <attributes key="kind" value="AND"/>
      <featureList id="3" name="Engine" featureType="ABSTRACT">
        <attributes key="category" value="powertrain"/>
        <groupNodeList id="11" name="EngineChoice">
          <attributes key="kind" value="XOR"/>
          <featureList id="4" name="GasolineEngine" featureType="CONCRETE">
            <attributes key="fuel" value="gasoline"/>
            <cardinality upperBound="1"/>
          </featureList>
          <featureList id="5" name="ElectricEngine" featureType="CONCRETE">
            <attributes key="fuel" value="electric"/>
            <cardinality upperBound="1"/>
          </featureList>
          <cardinality lowerBound="1" upperBound="1"/>
        </groupNodeList>
        <cardinality lowerBound="1" upperBound="1"/>
      </featureList>
      <featureList id="6" name="Comfort" featureType="ABSTRACT">
        <attributes key="category" value="interior"/>
        <groupNodeList id="12" name="ComfortGroup">
          <attributes key="kind" value="TEst"/>
          <featureList id="7" name="AirConditioning" featureType="CONCRETE">
            <attributes key="cost" value="medium"/>
            <cardinality lowerBound="1" upperBound="1"/>
          </featureList>
          <featureList id="8" name="SeatHeating">
            <attributes key="cost" value="high"/>
            <groupNodeList id="0fb8e1c1867a4a7798e49b2f354141ad" name="">
              <featureList id="540210e57a6f412f8bf691a95609e7c6" name="New Feature-1" featureType="CONCRETE">
                <cardinality upperBound="1"/>
              </featureList>
              <featureList id="60f5364d3e0e435298d6077dc9d738a6" name="New Feature-2" featureType="CONCRETE">
                <cardinality lowerBound="1" upperBound="1"/>
              </featureList>
              <featureList id="155ade5ba36d47e891a746273fe42754" name="New Feature-3" featureType="CONCRETE">
                <cardinality upperBound="1"/>
              </featureList>
              <featureList id="97dc51e758ea4ae29b98ee75185eef5b" name="New Feature-4" featureType="CONCRETE">
                <cardinality lowerBound="1" upperBound="1"/>
              </featureList>
              <featureList id="4601c7041770498c9530f7523116edc6" name="New Feature-5" featureType="CONCRETE">
                <cardinality upperBound="1"/>
              </featureList>
              <featureList id="9cea955c178c4c3f94747d6b20269ea6" name="New Feature-6" featureType="CONCRETE">
                <cardinality lowerBound="1" upperBound="1"/>
              </featureList>
              <cardinality lowerBound="1" upperBound="1"/>
            </groupNodeList>
            <cardinality upperBound="1"/>
          </featureList>
          <cardinality/>
        </groupNodeList>
        <cardinality upperBound="1"/>
      </featureList>
      <cardinality lowerBound="1"/>
    </groupNodeList>
    <cardinality lowerBound="1" upperBound="1"/>
  </roots>
  <constraints id="20" name="ElectricRequiresComfort">
    <attributes key="expr" value="ElectricEngine -> Comfort"/>
  </constraints>
  <constraints id="21" name="GasolineExcludesSeatHeating">
    <attributes key="expr" value="GasolineEngine -> not SeatHeating"/>
  </constraints>
</featJAR:FeatureModel>
